{
  "title": "[Hackintosh] Numpad Period: comma by default, period with Shift",
  "rules": [
    {
      "description": "Numpad period → comma; Shift+Numpad period → period",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "keypad_period",
            "modifiers": {
              "mandatory": ["shift"]
            }
          },
          "to": [
            { "key_code": "period" }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "keypad_period",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            { "key_code": "comma" }
          ]
        }
      ]
    }
  ]
}
