{
  "title": "Finder Shortcuts",
  "rules": [
    {
      "description": "Map Delete Forward to Move to Trash (Finder only)",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.apple\\.finder$"]
            },
            {
              "type": "variable_unless",
              "name": "finder_renaming",
              "value": 1
            }
          ],
          "from": { "key_code": "delete_forward" },
          "to": [
            {
              "key_code": "delete_or_backspace",
              "modifiers": ["left_command"]
            }
          ]
        }
      ]
    },
    {
      "description": "Map F2 to Rename (Finder only)",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.apple\\.finder$"]
            }
          ],
          "from": { "key_code": "f2" },
          "to": [
            {
              "key_code": "return_or_enter"
            },
            {
              "set_variable": {
                "name": "finder_renaming",
                "value": 1
              }
            }
          ]
        }
      ]
    },
    {
      "description": "Map Return to Open (Finder only)",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.apple\\.finder$"]
            },
            {
              "type": "variable_if",
              "name": "finder_renaming",
              "value": 1
            }
          ],
          "from": { "key_code": "return_or_enter" },
          "to": [
            {
              "key_code": "return_or_enter"
            },
            {
              "set_variable": {
                "name": "finder_renaming",
                "value": 0
              }
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.apple\\.finder$"]
            },
            {
              "type": "variable_unless",
              "name": "finder_renaming",
              "value": 1
            }
          ],
          "from": { "key_code": "return_or_enter" },
          "to": [
            {
              "key_code": "o",
              "modifiers": ["left_command"]
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.apple\\.finder$"]
            },
            {
              "type": "variable_if",
              "name": "finder_renaming",
              "value": 1
            }
          ],
          "from": { "key_code": "escape" },
          "to": [
            {
              "key_code": "escape"
            },
            {
              "set_variable": {
                "name": "finder_renaming",
                "value": 0
              }
            }
          ]
        }
      ]
    }
  ]
}
